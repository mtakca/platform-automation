! Keepalived Configuration for Bind9 HA
! Generated by Ansible

vrrp_script chk_named {
    script "/usr/bin/pgrep named"
    interval 2
    weight 2
}

vrrp_instance BIND9_VIP {
    state {{ 'MASTER' if bind9_mode == 'master' else 'BACKUP' }}
    interface {{ bind9_vip_interface }}
    virtual_router_id 53
    priority {{ bind9_keepalived_priority }}
    advert_int 1
    
    authentication {
        auth_type PASS
        auth_pass bind9ha
    }
    
    virtual_ipaddress {
        {{ bind9_vip }}/24
    }
    
    track_script {
        chk_named
    }
}
