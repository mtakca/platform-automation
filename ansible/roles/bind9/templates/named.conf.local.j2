// Local Zone Configuration
// Generated by Ansible
// Mode: {{ bind9_mode | default('master') }}

// Include TSIG key for dynamic updates
include "/etc/bind/keys/{{ bind9_tsig_keyname }}.key";

// Zone definition
zone "{{ bind9_zone_name }}" {
{% if bind9_mode | default('master') == 'master' %}
    type master;
    file "{{ bind9_zone_file }}";
    allow-update { key {{ bind9_tsig_keyname }}; };
    allow-transfer { {{ bind9_allow_transfer | join('; ') }}; {% if bind9_slave_ips is defined %}{% for ip in bind9_slave_ips %}{{ ip }}; {% endfor %}{% endif %}};
    also-notify { {% if bind9_slave_ips is defined %}{% for ip in bind9_slave_ips %}{{ ip }}; {% endfor %}{% endif %}};
{% else %}
    type slave;
    file "{{ bind9_zone_file }}";
    masters { {% for ip in bind9_master_ips %}{{ ip }}; {% endfor %}};
{% endif %}
};
