// Bind9 Options Configuration
// Generated by Ansible

options {
    directory "/var/cache/bind";

    // Listen on all interfaces
    listen-on { {{ bind9_listen_on | join('; ') }}; };
    listen-on-v6 { none; };

    // Forwarders
    forwarders {
{% for forwarder in bind9_forwarders %}
        {{ forwarder }};
{% endfor %}
    };

    // Query permissions
    allow-query { {{ bind9_allow_query | join('; ') }}; };

    // Recursion settings
    recursion yes;
    allow-recursion {
{% for network in bind9_trusted_networks %}
        {{ network }};
{% endfor %}
    };

    // DNSSEC validation
    dnssec-validation auto;

    // Misc options
    auth-nxdomain no;
    version "not disclosed";

    // Rate limiting
    rate-limit {
        responses-per-second 10;
    };
};
