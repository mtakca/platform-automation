# Kafka broker configuration - Generated by Ansible
# KRaft Configuration
process.roles=broker,controller
node.id={{ kafka_node_id | default(kafka_broker_id + 1 if kafka_is_ha else 1) }}
controller.quorum.voters={{ kafka_controller_quorum_voters }}

# Network settings
# Network settings
{% if kafka_sasl_enabled | default(false) %}
listeners=SASL_PLAINTEXT://:9092,CONTROLLER://:9093,SASL_SSL://:9094
inter.broker.listener.name=SASL_PLAINTEXT
advertised.listeners=SASL_PLAINTEXT://{{ ansible_host }}:9092
sasl.enabled.mechanisms=SCRAM-SHA-512
sasl.mechanism.inter.broker.protocol=SCRAM-SHA-512
listener.security.protocol.map=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,SSL:SSL,SASL_PLAINTEXT:SASL_PLAINTEXT,SASL_SSL:SASL_SSL
controller.listener.names=CONTROLLER
{% else %}
listeners=PLAINTEXT://:9092,CONTROLLER://:9093
inter.broker.listener.name=PLAINTEXT
advertised.listeners=PLAINTEXT://{{ ansible_host }}:9092
listener.security.protocol.map=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,SSL:SSL,SASL_PLAINTEXT:SASL_PLAINTEXT,SASL_SSL:SASL_SSL
controller.listener.names=CONTROLLER
{% endif %}


# Data directories
log.dirs={{ kafka_log_dir }}

# Replication settings
num.partitions=3
{% if kafka_is_ha %}
default.replication.factor=3
min.insync.replicas=2
{% else %}
default.replication.factor=1
min.insync.replicas=1
{% endif %}

# Log retention
log.retention.hours=168
log.segment.bytes=1073741824
log.retention.check.interval.ms=300000
