server {
    listen {{ nginx_port | default('443') }} ssl;
    server_name {{ nginx_server_name }};
    client_max_body_size {{ nginx_client_max_body_size | default('1000M') }};
    underscores_in_headers on;

{% if nginx_ssl_enabled | default(true) %}
    ssl_certificate /etc/nginx/ssl/cert.crt;
    ssl_certificate_key /etc/nginx/ssl/cert.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
{% endif %}

    # Security Headers
    add_header Strict-Transport-Security "max-age=31536000;includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-XSS-Protection "1; mode=block";
    add_header Referrer-Policy "strict-origin";
    add_header X-Content-Type-Options "nosniff";

    # Static files
    location /static {
        alias /static/;
        add_header Content-Security-Policy "default-src 'self'; font-src *;img-src * data:; script-src *; style-src *";
    }

    # Admin panel
    location /admin {
        proxy_pass http://{{ nginx_backend_host }}:{{ nginx_backend_port }}/admin;
        proxy_pass_request_headers on;
        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # Management API v2
    location /v2/management {
        proxy_pass http://{{ nginx_backend_host }}:{{ nginx_backend_port }}/v2/management;
        proxy_pass_request_headers on;
        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # Health check
    location /ping {
        proxy_pass http://{{ nginx_backend_host }}:{{ nginx_backend_port }}/ping;
        proxy_pass_request_headers on;
    }

    # Main API
    location /api {
        proxy_pass http://{{ nginx_backend_host }}:{{ nginx_backend_port }}/api;
        proxy_pass_request_headers on;
        include /etc/nginx/conf.d/proxy_params.conf;
    }

    # WebSocket
    location /socket {
        proxy_pass http://{{ nginx_backend_host }}:{{ nginx_backend_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Default - catch all
    location / {
        proxy_pass http://{{ nginx_backend_host }}:{{ nginx_backend_port }};
        proxy_pass_request_headers on;
        include /etc/nginx/conf.d/proxy_params.conf;
    }
}
