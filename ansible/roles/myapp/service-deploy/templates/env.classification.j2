SECRET_KEY={{ vault_flask_secret_key | default('CHANGE_ME') }}
FLASK_DEBUG=False
FLASK_ENV=production
LOG_LEVEL=WARNING
RABBITMQ_PORT=5672
RABBITMQ_USER=myapp
RABBITMQ_PASSWORD={{ vault_rabbitmq_password | default('CHANGE_ME') }}
RABBITMQ_HOST={{ hostvars[groups['rabbitmq'][0]]['keepalived_vip'] | default(hostvars[groups['rabbitmq'][0]]['ansible_host']) }}
RABBITMQ_VHOST=myapp
SENTRY_DSN={{ vault_sentry_dsn_classification | default('') }}
SENTRY_SERVER_NAME={{ sentry_server_name | default('MyApp') }}
SENTRY_ENVIRONMENT={{ sentry_environment | default('production') }}
SENTRY_ENABLED=False
OTLP_ENDPOINT=http://{{ hostvars[groups['myapp_elk'][0]]['ansible_host'] | default('10.0.X.X') }}:4317
