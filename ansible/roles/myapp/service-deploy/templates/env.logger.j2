SECRET_KEY={{ vault_flask_secret_key | default('CHANGE_ME') }}
FLASK_DEBUG=False
FLASK_ENV=production
LOG_LEVEL=WARNING
RABBIT_MQ_PORT=5672
RABBIT_MQ_USER_NAME=myapp
RABBIT_MQ_PASSWORD={{ vault_rabbitmq_password | default('CHANGE_ME') }}
RABBIT_MQ_HOST={{ hostvars[groups['rabbitmq'][0]]['keepalived_vip'] | default(hostvars[groups['rabbitmq'][0]]['ansible_host']) }}
RABBITMQ_VHOST=myapp
MONGO_DB_URI=mongodb://{{ vault_mongodb_user | default('mongodbadmin') }}:{{ vault_mongodb_password | default('CHANGE_ME') }}@{{ hostvars[groups['myapp_mongodb'][0]]['ansible_host'] }}:27017/?authMechanism=DEFAULT&authSource=admin
MONGO_DB_PORT=27017
MONGO_DB_NAME={{ mongodb_logger_db | default('logger_db') }}
SERVER_ID={{ server_id | default('example_server') }}
SENTRY_DSN={{ vault_sentry_dsn_logger | default('') }}
SENTRY_SERVER_NAME={{ sentry_server_name | default('MyApp') }}
SENTRY_ENVIRONMENT={{ sentry_environment | default('production') }}
SENTRY_ENABLED=False
OTLP_ENDPOINT=http://{{ hostvars[groups['myapp_elk'][0]]['ansible_host'] | default('10.0.X.X') }}:4317
