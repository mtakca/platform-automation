# Redis configuration - Generated by Ansible
bind 0.0.0.0
port 6379
protected-mode yes

# Authentication
requirepass {{ redis_password }}
masterauth {{ redis_password }}

# Systemd manages the process, no daemonize needed
supervised systemd
pidfile /run/redis/redis-server.pid

# Data persistence
dir {{ redis_data_dir }}
dbfilename dump.rdb
save 900 1
save 300 10
save 60 10000

# Logging
logfile {{ redis_log_dir }}/redis-server.log
loglevel notice

# Replication (HA mode)
replica-announce-ip {{ ansible_host }}
replica-announce-port 6379

{% if redis_is_ha and redis_master_ip != ansible_host %}
# This is a replica node
replicaof {{ redis_master_ip }} 6379
{% endif %}

# Memory management
maxmemory-policy allkeys-lru

# Append-only file (AOF) for durability
appendonly yes
appendfilename "appendonly.aof"
appendfsync everysec
