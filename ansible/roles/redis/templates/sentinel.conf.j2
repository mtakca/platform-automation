# Redis Sentinel configuration - Generated by Ansible
port 26379
bind 0.0.0.0

# Working directory
dir {{ redis_data_dir }}

# Monitor master
sentinel monitor mymaster {{ redis_master_ip }} 6379 2

# Authentication - CRITICAL for Sentinel to connect to Redis
{% if redis_password is defined and redis_password %}
sentinel auth-pass mymaster {{ redis_password }}
{% endif %}

# Timeouts
sentinel down-after-milliseconds mymaster 5000
sentinel failover-timeout mymaster 60000
sentinel parallel-syncs mymaster 1

# Announce
sentinel announce-ip {{ ansible_host }}

# Logging
logfile {{ redis_log_dir }}/sentinel.log
