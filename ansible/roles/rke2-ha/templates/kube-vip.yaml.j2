apiVersion: v1
kind: Pod
metadata:
  name: kube-vip
  namespace: kube-system
spec:
  # Kubernetes service DNS resolution için gerekli
  hostAliases:
    - hostnames:
        - kubernetes
        - kubernetes.default
        - kubernetes.default.svc
      ip: 127.0.0.1
  hostNetwork: true
  containers:
    - name: kube-vip
      image: {{ kube_vip_image }}
      imagePullPolicy: IfNotPresent
      args:
        - manager
      env:
        # Control Plane VIP
        - name: cp_enable
          value: "true"
        - name: cp_namespace
          value: "kube-system"
        # ARP Mode
        - name: vip_arp
          value: "true"
        # VIP Configuration
        - name: port
          value: "6443"
        - name: vip_interface
          value: "{{ (kube_vip_interface | length > 0) | ternary(kube_vip_interface, ansible_default_ipv4.interface) }}"
        - name: address
          value: "{{ k8s_api_vip }}"
        - name: vip_cidr
          value: "32"
        # Leader Election (single master için false olabilir)
        - name: vip_leaderelection
          value: "true"
        - name: vip_leaseduration
          value: "5"
        - name: vip_renewdeadline
          value: "3"
        - name: vip_retryperiod
          value: "1"
        # Service LoadBalancer support
        - name: svc_enable
          value: "{{ 'true' if kube_vip_enable_svc else 'false' }}"
        # DDNS disabled
        - name: vip_ddns
          value: "false"
      volumeMounts:
        - name: kubeconfig
          mountPath: /etc/kubernetes/admin.conf
          readOnly: true
      securityContext:
        capabilities:
          add:
            - NET_ADMIN
            - NET_RAW
            - SYS_TIME
  volumes:
    - name: kubeconfig
      hostPath:
        path: /etc/rancher/rke2/rke2.yaml
        type: File
