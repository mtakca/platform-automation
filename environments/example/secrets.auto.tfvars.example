################################################################################
# SECRETS CONFIGURATION TEMPLATE
# DO NOT COMMIT THE REAL secrets.auto.tfvars FILE TO VERSION CONTROL
# Rename this file to secrets.auto.tfvars and fill in your actual credentials.
################################################################################

# VMWare Cloud Director (vCD)
# NOTE: vcd_access_token should be passed via environment variables (VCD_REFRESH_TOKEN) 
# and the Makefile automation script, but can be hardcoded here for testing.
vcd_access_token = "xxxx-xxxx-xxxx-xxxx"

# Virtual Machine Default Passwords
root_password    = "SuperSecretRootPassword2026!"
default_password = "SuperSecretUserPassword2026!"

# OPNsense API (If firewall is enabled)
opnsense_api_key    = "fill-opnsense-api-key-here"
opnsense_api_secret = "fill-opnsense-api-secret-here"

# SSH Keys for automated insertion (vApp Users)
users = [
  {
    username = "admin_user"
    ssh_key  = "ssh-rsa AAAAB3NzaC1yc... user@example.local"
  },
  {
    username = "ci_cd_user"
    ssh_key  = "ssh-ed25519 AAAAC3NzaC... runner@gitlab"
  }
]
